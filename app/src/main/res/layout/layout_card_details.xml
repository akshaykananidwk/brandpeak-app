<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"

    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/_10ssp"
        android:background="@drawable/dialog_background"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_centerInParent="true"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_10ssp"
                    android:layout_marginTop="@dimen/_10ssp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_10ssp"
                        android:paddingVertical="@dimen/_2ssp"
                        android:text="Amount in USD : "
                        android:textColor="@color/black"
                        android:textSize="@dimen/_12ssp" />

                    <TextView
                        android:id="@+id/amount_usd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_10ssp"
                        android:gravity="right"
                        android:paddingVertical="@dimen/_2ssp"
                        android:text=""
                        android:textColor="@color/black"
                        android:textSize="@dimen/_12ssp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|right"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/_8ssp"
                        android:visibility="visible"
                        app:cardBackgroundColor="@color/amber_800"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="3dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="180dp"
                                android:layout_alignParentStart="true"
                                android:layout_alignParentLeft="true"
                                android:layout_alignParentTop="true"
                                android:scaleType="centerCrop"
                                android:src="@drawable/world_map" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:orientation="vertical"
                                android:paddingLeft="@dimen/_15ssp"
                                android:paddingRight="@dimen/_15ssp">

                                <ImageView
                                    android:id="@+id/card_logo"
                                    android:layout_width="100dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="end|right"
                                    android:elevation="@dimen/_2ssp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/icvisa" />

                                <TextView
                                    android:id="@+id/card_number"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/_5ssp"
                                    android:fontFamily="monospace"
                                    android:text="**** **** **** ****"
                                    android:textAppearance="@style/Base.TextAppearance.AppCompat.Headline"
                                    android:textColor="@android:color/white" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/_10ssp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="horizontal">

                                            <LinearLayout
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:orientation="vertical">

                                                <TextView
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:text="EXPIRE"
                                                    android:textAppearance="@style/Base.TextAppearance.AppCompat.Body1"
                                                    android:textColor="@color/gray_hint" />

                                                <TextView
                                                    android:id="@+id/card_expire"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:fontFamily="monospace"
                                                    android:text="MM/YYYY"
                                                    android:textAppearance="@style/Base.TextAppearance.AppCompat.Subhead"
                                                    android:textColor="@android:color/white" />

                                            </LinearLayout>

                                            <View
                                                android:layout_width="@dimen/_20ssp"
                                                android:layout_height="0dp" />

                                            <LinearLayout
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:orientation="vertical">

                                                <TextView
                                                    android:id="@+id/cvv"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:text="CVV"
                                                    android:textAppearance="@style/Base.TextAppearance.AppCompat.Body1"
                                                    android:textColor="@color/gray_hint" />

                                                <TextView
                                                    android:id="@+id/card_cvv"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:fontFamily="monospace"
                                                    android:text="***"
                                                    android:textAppearance="@style/Base.TextAppearance.AppCompat.Subhead"
                                                    android:textColor="@android:color/white" />
                                            </LinearLayout>

                                        </LinearLayout>

                                        <View
                                            android:layout_width="0dp"
                                            android:layout_height="@dimen/_10ssp" />

                                        <TextView
                                            android:id="@+id/card_name"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:fontFamily="monospace"
                                            android:text="Your Name"
                                            android:textAppearance="@style/Base.TextAppearance.AppCompat.Medium"
                                            android:textColor="@android:color/white" />

                                    </LinearLayout>

                                    <ImageView
                                        android:layout_width="50dp"
                                        android:layout_height="50dp"
                                        android:layout_gravity="bottom"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/ic_copper_card" />

                                </LinearLayout>

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/_10ssp" />
                            </LinearLayout>

                        </RelativeLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/_15ssp"
                    android:paddingRight="@dimen/_15ssp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_10ssp" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_card_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="-4dp"
                        android:layout_marginRight="-4dp"
                        android:hint="Card number"
                        android:inputType="number"
                        android:maxLength="16"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="@color/blue_grey_800"
                        android:textColorHint="@color/gray_hint" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_10ssp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_expire"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="-4dp"
                            android:layout_marginRight="-4dp"
                            android:layout_weight="1"
                            android:hint="MM/YYYY"
                            android:inputType="numberDecimal"
                            android:maxLength="6"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/blue_grey_800"
                            android:textColorHint="@color/gray_hint" />

                        <View
                            android:layout_width="@dimen/_10ssp"
                            android:layout_height="0dp" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cvv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="-4dp"
                            android:layout_marginRight="-4dp"
                            android:layout_weight="1"
                            android:hint="CVV"
                            android:inputType="number"
                            android:maxLength="3"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/blue_grey_800"
                            android:textColorHint="@color/gray_hint" />

                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_10ssp" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="-4dp"
                        android:layout_marginRight="-4dp"
                        android:hint="Name on card"
                        android:inputType="text"
                        android:maxLength="14"
                        android:focusable="true"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="@color/blue_grey_800"
                        android:textColorHint="@color/gray_hint" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5ssp"
                    android:padding="@dimen/_10ssp">

                    <Button
                        android:id="@+id/btn_continue"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_phone_btn"
                        android:text="CONTINUE"
                        android:textAllCaps="false"
                        android:textAppearance="@style/Base.TextAppearance.AppCompat.Subhead"
                        android:textColor="@android:color/white" />
                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </RelativeLayout>

</LinearLayout>